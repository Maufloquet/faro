rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Ocorrências: leitura pública (modo passivo do app), escrita só por
    // Cloud Functions (admin SDK). Usuários NÃO podem reportar direto na
    // collection — reports passam por moderação separada na V2.
    match /occurrences/{occurrenceId} {
      allow read: if true;
      allow write: if false;
    }

    // Reports de usuários (Camada 4 — UGC). Caixa de entrada crua de
    // relatos. Ficam separados de /occurrences de propósito: enquanto não
    // validados coletivamente, são "boato" e não devem poluir digest,
    // narrativas nem densidade. A Cloud Function promove os confirmados
    // pra /occurrences com source='user_report'.
    //
    // - Leitura pública: o app mostra relatos pendentes como camada
    //   distinta ("não confirmado").
    // - Create: usuário autenticado, GPS obrigatório (lat/lng numéricos),
    //   tipo válido, status inicial 'pending', contagens zeradas, autoria
    //   amarrada ao uid. Descrição opcional e curta. expiresAt obrigatório
    //   (cliente põe agora+4h; a Function de expiração é a fonte real).
    // - Update/delete pelo cliente: bloqueado. Mudança de status e
    //   contagens só via Cloud Function (admin SDK). Voto vai na subcoleção.
    match /reports/{reportId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        && request.resource.data.lat >= -90 && request.resource.data.lat <= 90
        && request.resource.data.lng >= -180 && request.resource.data.lng <= 180
        && request.resource.data.type is string
        && request.resource.data.status == 'pending'
        && request.resource.data.confirmCount == 0
        && request.resource.data.contestCount == 0
        && (request.resource.data.description == null
            || (request.resource.data.description is string
                && request.resource.data.description.size() <= 280))
        && request.resource.data.expiresAt is timestamp;
      allow update, delete: if false;

      // Voto de validação coletiva — id determinístico = uid do votante,
      // garante 1 voto por usuário por relato. Bloco 2 agrega via Function.
      match /votes/{voterUid} {
        allow read: if request.auth != null && request.auth.uid == voterUid;
        allow create, update: if request.auth != null
          && request.auth.uid == voterUid
          && request.resource.data.vote in ['confirm', 'contest'];
        allow delete: if false;
      }
    }

    // Users — perfil e dados sincronizados. Cada um lê/escreve só o próprio.
    // O doc do user guarda referenceLocation (hotel/casa). Validação de
    // estrutura mantém a regra simples — sem listar todos os campos.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Subcoleção de favoritos do usuário. Mesmo dono lê/escreve. Doc id
      // é o slug do bairro (ex.: "mata-escura") — gerado client side via
      // normalizeNeighborhoodId em favorites_service.dart.
      match /favorites/{favoriteId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.name is string
          && request.resource.data.lat is number
          && request.resource.data.lng is number;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Tokens FCM do usuário — usados pela Cloud Function `dailyDigest`
      // pra mandar push direto pro device. Doc id é o token. Validação
      // mínima: campo `token` string, `platform` string.
      match /fcmTokens/{tokenId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null
          && request.auth.uid == userId
          && (
            request.resource == null
            || (
              request.resource.data.token is string
              && request.resource.data.platform is string
            )
          );
      }
    }

    // Regions — score agregado por região. Leitura pública, escrita só Cloud Function.
    match /regions/{regionId} {
      allow read: if true;
      allow write: if false;
    }

    // Narratives — clusters semanais de ocorrências relacionadas via
    // embedding semântico (scheduler aggregateNarratives). Leitura
    // pública porque alimenta a seção "Esta semana" da UI. Escrita só
    // via Cloud Function com admin SDK.
    match /narratives/{narrativeId} {
      allow read: if true;
      allow write: if false;
    }

    // Contestations — usuário autenticado (mesmo anonymous) pode criar
    // ou atualizar a própria contestação (mudou de ideia sobre o motivo).
    //
    // Rate limit grátis via doc id determinístico: contestationId precisa
    // ser exatamente '{uid}_{occurrenceId}'. Resultado: 1 contestação por
    // usuário por ocorrência, no máximo. Spam fica limitado ao número de
    // ocorrências ativas. Aggregator do server conta UIDs distintos, então
    // o resultado não muda — só impede inflar count com lixo.
    //
    // Leitura bloqueada: visíveis só via admin/dashboard. Delete bloqueado
    // pelo cliente — moderação reversa é via Console Firebase / Admin SDK.
    match /contestations/{contestationId} {
      allow read: if false;
      allow create: if request.auth != null
        && request.resource.data.occurrenceId is string
        && request.resource.data.reason is string
        && request.resource.data.submittedBy == request.auth.uid
        && contestationId == request.auth.uid + '_' + request.resource.data.occurrenceId
        && (request.resource.data.detail == null
            || (request.resource.data.detail is string
                && request.resource.data.detail.size() < 500));
      allow update: if request.auth != null
        && request.auth.uid == resource.data.submittedBy
        && request.resource.data.occurrenceId == resource.data.occurrenceId
        && request.resource.data.submittedBy == resource.data.submittedBy
        && (request.resource.data.detail == null
            || (request.resource.data.detail is string
                && request.resource.data.detail.size() < 500));
      allow delete: if false;
    }

    // Safe arrivals — "Cheguei bem". Sinal POSITIVO anônimo, agregado
    // por (geohash5, dia). Doc id = "{cell}_{day}".
    //
    // - Leitura pública: app precisa exibir contagens nos cards
    // - Create: user autenticado (anonymous basta), count=1 no primeiro
    //   registro do dia. Validamos campos pra evitar lixo.
    // - Update: só pode incrementar count em +1 a cada vez. Anti-spam
    //   minimal — escrita massiva fica vidente em audit log.
    match /safe_arrivals/{cellDay} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.cell is string
        && request.resource.data.cell.size() == 5
        && request.resource.data.day is string
        && request.resource.data.count == 1;
      allow update: if request.auth != null
        && request.resource.data.cell == resource.data.cell
        && request.resource.data.day == resource.data.day
        && request.resource.data.count == resource.data.count + 1;
      allow delete: if false;
    }

    // News seen — cache do pipeline de ingest pra dedupar URLs já
    // classificadas. Só Cloud Functions (admin SDK) bypassa as rules
    // pra escrever. Bloqueado pra todos os clientes.
    match /news_seen/{hash} {
      allow read, write: if false;
    }

    // OSM — pontos de ônibus e outras camadas mapeadas (single docs
    // grandes, atualizados manualmente via osmFetch HTTP function).
    // Leitura pública (app consome direto), escrita só admin.
    match /osm/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Research keys — chaves de API pra pesquisadores credenciados
    // (UFBA, USP etc.) consumirem o endpoint /api/v1/occurrences.
    // Gerenciadas manualmente pelo admin via Console. Clientes nunca
    // leem/escrevem direto — todo o auth-check é server-side na
    // Cloud Function getOccurrences. Audit log (subcoleção usage) idem.
    match /research_keys/{keyId} {
      allow read, write: if false;
      match /usage/{day} {
        allow read, write: if false;
      }
    }

    // System health — heartbeat dos schedulers, escrito por cada Cloud
    // Function no fim do run (helper functions/lib/jobHealth.js). Leitura
    // gateada por custom claim admin pro painel exibir o grid de saúde.
    match /system_health/{job} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // Admin metrics — agregação operacional escrita por Cloud Function
    // a cada 30 min. Leitura gateada por custom claim `admin: true`
    // (concedido via functions/scripts/grantAdmin.js). Cliente comum
    // não tem o claim, então as rules barram a leitura mesmo se ele
    // adivinhar a rota.
    match /admin_metrics/{doc} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;

      match /daily/{day} {
        allow read: if request.auth != null && request.auth.token.admin == true;
        allow write: if false;
      }
    }

    // Tudo o que não estiver mapeado: fechado por default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
