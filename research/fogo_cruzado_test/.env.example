# Renomeie para .env e preencha
# A API atual do Fogo Cruzado pode usar email/senha + token JWT em vez de API key estática.
# Verifique a doc atualizada em https://api.fogocruzado.org.br

FOGO_CRUZADO_EMAIL=seuemail@exemplo.com
FOGO_CRUZADO_PASSWORD=sua_senha_aqui

# Caso a API exponha token estático no futuro:
# FOGO_CRUZADO_KEY=
